# === DATABASE ===
DATABASE_URL="postgresql://catalogo:catalogo@localhost:5435/mercantia_admin"

# === AUTH ===
# bcrypt hash, generate with: npm run hash-password "your-password-here"
ADMIN_PASSWORD="cambiame_hash_bcrypt"
# Random string for HMAC + AES-256-GCM. Generate with: openssl rand -hex 32
SESSION_SECRET="cambiame_string_largo_aleatorio_64_chars_minimo"
SESSION_MAX_AGE_HOURS="12"

# === PANEL ===
PANEL_URL="http://localhost:3010"
NODE_ENV="development"
