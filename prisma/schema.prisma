generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  apiUrl    String
  apiToken  String
  status    String   @default("active")
  notes     String?

  // Backup destination override. Si null, se usa el target con isDefault=true.
  // El subdir, si null, cae a slug del tenant.
  backupTargetId String?
  backupTarget   BackupTarget? @relation("TenantBackupTarget", fields: [backupTargetId], references: [id], onDelete: SetNull)
  backupSubdir   String?

  // Programación automática de backups. Si scheduleEnabled=true, el worker
  // del panel dispara backup_now + sync a las horas indicadas.
  // - scheduleHours: array de horas en formato 0-23 (hora local del panel).
  //   Ej: [3] = una vez al día a las 3am. [3, 15] = dos veces al día.
  // - retention: número máximo de ficheros a conservar en el target.
  //   El worker borra los más antiguos al exceder este número.
  backupScheduleEnabled Boolean @default(false)
  backupScheduleHours   Int[]   @default([])
  backupRetention       Int     @default(30)
  backupLastRunAt       DateTime?
  backupLastRunStatus   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncs        BackupSync[]
  logs         OperationLog[]
  subscription TenantSubscription?
  payments     Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  amount    Int
  type      String
  paidAt    DateTime
  method    String?
  notes     String?
  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, paidAt])
  @@index([type, paidAt])
}

model Plan {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String

  monthlyPrice    Int
  yearlyPrice     Int

  maxAdmins       Int
  maxOffice       Int
  maxSales        Int

  multiWarehouse  Boolean  @default(false)
  apiAccess       Boolean  @default(false)

  description     String?
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   TenantSubscription[]
}

model TenantSubscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId          String?
  plan            Plan?    @relation(fields: [planId], references: [id])

  customMaxAdmins      Int?
  customMaxOffice      Int?
  customMaxSales       Int?
  customMultiWarehouse Boolean?
  customApiAccess      Boolean?

  contractStartDate  DateTime?
  billingCycle       String?
  customMonthlyPrice Int?

  installationPrice  Int?
  installationPaidAt DateTime?

  nextPaymentDate    DateTime?
  paymentStatus      String?  @default("active")
  paymentMethod      String?

  lastSyncedAt       DateTime?
  syncStatus         String?
  syncError          String?

  notes              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([planId])
  @@index([paymentStatus])
}

model BackupTarget {
  id         String   @id @default(cuid())
  name       String
  host       String
  port       Int      @default(22)
  username   String
  sshKeyPath String
  remotePath String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  syncs   BackupSync[]
  tenants Tenant[]     @relation("TenantBackupTarget")
}

model BackupSync {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  backupTargetId String?
  backupTarget   BackupTarget? @relation(fields: [backupTargetId], references: [id])
  sourceFile     String
  status         String
  sizeBytes      BigInt?
  durationMs     Int?
  errorMessage   String?
  createdAt      DateTime      @default(now())

  @@index([tenantId, createdAt])
}

model OperationLog {
  id           String   @id @default(cuid())
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  action       String
  actor        String   @default("admin")
  details      Json?
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
}
